{
  "name": "@ps/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --banner:js=\"import{createRequire as __cr}from'node:module';const require=__cr(import.meta.url);\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ps/shared": "*",
    "@ps/engine": "*",
    "@ps/bots": "*",
    "ws": "8.17.1"
  },
  "devDependencies": {
    "@types/ws": "8.5.10",
    "esbuild": "0.21.5",
    "tsx": "4.16.2"
  }
}
